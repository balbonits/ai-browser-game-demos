{
  "name": "ai-browser-game-demos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A collection of browser games built entirely by AI (Claude Code, PixelLab.ai, etc.). React + Vite landing shell; vanilla static games.",
  "homepage": "https://games.jdilig.me",
  "author": "John Dilig",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/balbonits/ai-browser-game-demos.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "test": "npm run test:unit && npm run test:property && npm run test:e2e",
    "test:unit": "vitest run --project=unit --project=replay",
    "test:property": "vitest run --project=property",
    "test:e2e": "playwright test",
    "test:watch": "vitest --project=unit --project=replay"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.14.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "fast-check": "^4.7.0",
    "husky": "^9.1.7",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.5"
  }
}
