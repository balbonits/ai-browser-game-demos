# Files that shouldn't be uploaded to Vercel.
# Vercel does NOT auto-respect .gitignore — this file mirrors what we
# don't want shipped (local Claude state, agent worktrees, OS junk).

.git
.gitignore
.claude
.vercel
.DS_Store
node_modules
dist
*.log

# Documentation isn't needed at runtime — the docs folder is a github-only artifact.
docs

# Repo metadata that doesn't need to ship as part of the static site.
README.md
AGENTS.md
CLAUDE.md
CHANGELOG.md

# License files DO ship — Vite copies them into dist/ via the
# rootLicenseFiles plugin so per-game footer links keep working.
# (LICENSE, LICENSE-ASSETS — explicitly NOT excluded here.)
